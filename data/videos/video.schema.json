{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Radar Panel Video Config",
  "type": "object",
  "required": ["templateId", "meta", "theme", "animation", "items"],
  "properties": {
    "templateId": {
      "type": "string"
    },
    "meta": {
      "type": "object",
      "required": ["title", "series", "topic", "durationPerItem"]
    },
    "theme": {
      "type": "object",
      "required": ["background", "radarAxes"]
    },
    "animation": {
      "type": "object",
      "required": ["characterEnter", "radarBuild", "transition"]
    },
    "items": {
      "type": "array",
      "minItems": 1
    }
  }
}
